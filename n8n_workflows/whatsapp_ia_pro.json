            { "id": "9",  "name": "contact_name",     "value": "={{ $('📋 Extraer Datos del Mensaje').item.json.contact_name }}", "type": "string" },
            { "id": "10", "name": "base_url",         "value": "={{ $('⚙️ Merge Config').item.json.base_url || 'https://osw.conectaai.cl/api/v1' }}", "type": "string" },
            { "id": "11", "name": "ai_model",         "value": "={{ $('⚙️ Merge Config').item.json.ai_model }}", "type": "string" },
            { "id": "12", "name": "ai_provider",      "value": "={{ $('⚙️ Merge Config').item.json.ai_provider }}", "type": "string" }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [2120, 560],
      "id": "extract-response",
      "name": "💬 Extraer Respuesta IA"
    },
    {
      "parameters": {
        "jsCode": "// Actualizar memoria de conversación con el nuevo intercambio\nconst staticData = $getWorkflowStaticData('global');\nconst phone = $json.phone;\n\nif (!staticData.conversations) staticData.conversations = {};\nconst history = staticData.conversations[phone] || [];\n\nhistory.push({ role: 'user',      content: $json.user_message });\nhistory.push({ role: 'assistant', content: $json.ai_response });\n\n// Máximo 20 mensajes en memoria (10 intercambios)\nstaticData.conversations[phone] = history.slice(-20);\n\nreturn [{ json: $input.item.json }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2400, 560],
      "id": "save-history",
      "name": "💾 Guardar en Memoria"
    },
    {
      "parameters": {
        "jsCode": "// Clean AI response — detect and remove special tags, no HTTP calls\nconst rawResponse = $json.ai_response || '';\nlet cleanedResponse = rawResponse;\nlet shouldEscalate = false;\n\nif (rawResponse.includes('ESCALAR_HUMANO')) {\n  shouldEscalate = true;\n  cleanedResponse = cleanedResponse.replace(/ESCALAR_HUMANO/g, '').trim();\n}\n\nconst quoteMatch = rawResponse.match(/COTIZACION_WA:([\\s\\S]+?)(?=\\n\\nESCALAR_HUMANO|\\n\\n[A-Z]|$)/);\nlet quoteText = null;\nlet quoteValue = null;\nif (quoteMatch) {\n  quoteText = quoteMatch[1].trim();\n  const valueMatch = quoteText.match(/\\$\\s*([\\d]{1,3}(?:[.,]\\d{3})*)/);\n  quoteValue = valueMatch ? parseFloat(valueMatch[1].replace(/[.,]/g, '')) : null;\n  cleanedResponse = cleanedResponse.replace(/COTIZACION_WA:[\\s\\S]+?(?=\\n\\n[A-Z]|$)/, '').trim();\n}\n\nif (!cleanedResponse) {\n  cleanedResponse = shouldEscalate\n    ? '¡Perfecto! Te estoy conectando con un asesor. 👨‍💼'\n    : rawResponse;\n}\n\nreturn [{ json: { ...($input.item.json), ai_response: cleanedResponse, should_escalate: shouldEscalate, quote_text: quoteText, quote_value: quoteValue } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2680, 560],
      "id": "detect-action",
      "name": "🎯 Detectar Acción"
    },
