    {
      "parameters": {
        "jsCode": "// Merge tenant config response with defaults\nconst apiSecret = 'n8n_omniflow_bb381df03a4fa5e2706c0e11fd468468';\nconst baseUrl = 'https://osw.conectaai.cl/api/v1';\nconst extracted = $('📋 Extraer Datos del Mensaje').item.json;\nconst cfg = $input.item.json; // Response from HTTP Request or error object\n\nconst subdomain = cfg.subdomain || 'osw';\nconst waToken = cfg.whatsapp_token || null;\nconst systemPrompt = cfg.system_prompt || 'Eres un asistente virtual amable. Responde en español.';\nconst aiProvider = cfg.ai_provider || 'groq';\nconst aiModel = cfg.ai_model || 'llama-3.3-70b-versatile';\n\nreturn [{\n  json: {\n    ...extracted,\n    subdomain,\n    whatsapp_token: waToken,\n    system_prompt: systemPrompt,\n    ai_provider: aiProvider,\n    ai_model: aiModel,\n    api_secret: apiSecret,\n    base_url: baseUrl,\n    has_token: !!(waToken),\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1060, 560],
      "id": "merge-config",
      "name": "⚙️ Merge Config"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://osw.conectaai.cl/api/v1/internal/contact/upsert",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-API-Secret", "value": "n8n_omniflow_bb381df03a4fa5e2706c0e11fd468468" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ subdomain: $json.subdomain, external_id: $json.phone, name: $json.contact_name || 'Cliente WhatsApp', phone: '+' + $json.phone, source: 'whatsapp' }) }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1280, 760],
      "id": "upsert-contact",
      "name": "👤 Registrar Contacto WA",
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// ─────────────────────────────────────────────────────────────────\n// MEMORIA DE CONVERSACIÓN por número de teléfono\n// Almacena los últimos 10 mensajes (5 intercambios) por usuario\n// ─────────────────────────────────────────────────────────────────\nconst staticData = $getWorkflowStaticData('global');\nconst phone = $json.phone;\nconst systemPrompt = $json.system_prompt;\nconst userMessage = $json.message;\n\nif (!staticData.conversations) staticData.conversations = {};\nconst history = staticData.conversations[phone] || [];\n\n// Últimos 10 mensajes para contexto\nconst recentHistory = history.slice(-10);\n\n// Array de mensajes para la IA\nconst messages = [\n  { role: 'system', content: systemPrompt },\n  ...recentHistory,\n  { role: 'user', content: userMessage }\n];\n\nreturn [{ json: { ...($input.item.json), messages_for_ai: messages, history_count: recentHistory.length } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1280, 560],
      "id": "get-history",
      "name": "📚 Cargar Historial (Memoria)"
    },
    {
      "parameters": {
