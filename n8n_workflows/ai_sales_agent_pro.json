        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"model\":\"llama-3.1-8b-instant\",\"messages\":[{\"role\":\"system\",\"content\":\"Eres un clasificador de leads para una tienda de cortinas y persianas llamada TerraBlinds. Analiza el mensaje y responde SOLO con un JSON con estos campos: {intent: string (cotizacion|info_producto|soporte|spam|saludo), urgency: string (alta|media|baja), product: string (nombre del producto si se menciona, si no general), extracted_name: string o null, extracted_phone: string o null, extracted_email: string o null, summary: string (resumen en 10 palabras)}\"},{\"role\":\"user\",\"content\":\"{{ $json.first_message }}\"}],\"max_tokens\":200,\"temperature\":0.1}",
        "options": {}
      },
      "id": "groq-classify",
      "name": "🤖 Groq: Clasificar Intención",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [400, 300],
      "credentials": {
        "httpHeaderAuth": {
          "id": "groq-auth",
          "name": "Groq API Key"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst choice = raw.choices?.[0]?.message?.content || '{}';\nlet classification;\ntry {\n  const clean = choice.replace(/```json\\n?/g,'').replace(/```/g,'').trim();\n  classification = JSON.parse(clean);\n} catch(e) {\n  classification = { intent: 'cotizacion', urgency: 'media', product: 'general', extracted_name: null, extracted_phone: null, extracted_email: null, summary: 'Lead sin clasificar' };\n}\n\nconst prev = $('📋 Variables del Lead').first().json;\nreturn [{\n  json: {\n    ...prev,\n    intent: classification.intent || 'cotizacion',\n    urgency: classification.urgency || 'media',\n    product: classification.product || 'general',\n    extracted_name: classification.extracted_name,\n    extracted_phone: classification.extracted_phone,\n    extracted_email: classification.extracted_email,\n    summary: classification.summary || '',\n    is_spam: classification.intent === 'spam',\n  }\n}];"
      },
      "id": "parse-classification",
      "name": "🔍 Parsear Clasificación",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [600, 300]
    },
